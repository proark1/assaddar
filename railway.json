{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm check:migrations && pnpm build"
  },
  "deploy": {
    "preDeployCommand": "pnpm check:production && pnpm check:migrations",
    "startCommand": "pnpm start",
    "healthcheckPath": "/de/login",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
