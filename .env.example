# Public site/contact. These can also be managed in Portal Admin -> Settings.
RESEND_API_KEY=
CONTACT_FROM_EMAIL="ASSADDAR Website <hello@assad-dar.de>"
CRM_FROM_EMAIL="ASET STAR CRM <crm@aset-star.de>"
RESEND_WEBHOOK_SECRET=
NEXT_PUBLIC_CAL_LINK=

# Assaddar AI communication widget. Empty = production only; true = force on; false = force off.
NEXT_PUBLIC_ASSADDAR_WIDGET_ENABLED=
NEXT_PUBLIC_ASSADDAR_WIDGET_URL=https://assaddar-widget-production.up.railway.app/widget.js
NEXT_PUBLIC_ASSADDAR_API_URL=https://assaddar-api-production.up.railway.app
NEXT_PUBLIC_ASSADDAR_ASSISTANT_ID=asst_5965790b88cc480b836f5eca

# Required before using the portal with real customers.
# Generate a long random value, for example:
# openssl rand -base64 48
AUTH_SECRET=
APP_URL=http://localhost:3000
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_COOKIE_DOMAIN=
PORTAL_ADMIN_BOOTSTRAP_PASSWORD=
# Development only. Leave empty in production.
PORTAL_DEMO_CUSTOMER_PASSWORD=
CRON_SECRET=
PORTAL_MAX_UPLOAD_BYTES=12582912
BLOG_HERO_MAX_UPLOAD_BYTES=5242880
BLOG_IMAGE_TIMEOUT_MS=45000
BLOG_IMAGE_MAX_BYTES=8388608

# Portal data backend.
# local = development/demo JSON store in .portal-data
# postgres = Supabase/Postgres using DATABASE_URL
PORTAL_DATA_BACKEND=local
DATABASE_URL=

# Later production integrations. AI/email keys can also be stored in Portal
# Admin -> Settings after migrations are applied.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PORTAL_FILE_STORAGE=local
SUPABASE_STORAGE_BUCKET=portal-files

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
GROK_API_KEY=
GROK_MODEL=
GROK_API_BASE=https://api.x.ai/v1
# false/empty = redact project/customer names before external AI scans.
EXTERNAL_AI_SEND_IDENTIFIERS=false

# Website intelligence crawler guardrails.
WEBSITE_CRAWL_MAX_PAGES=14
WEBSITE_CRAWL_MAX_DEPTH=2
WEBSITE_CRAWL_TIMEOUT_MS=8000
WEBSITE_CRAWL_MAX_TEXT_CHARS=4500
WEBSITE_CRAWL_RENDERED_FALLBACK=false
WEBSITE_CRAWL_RENDERED_FALLBACK_MIN_WORDS=80
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

# Admin-only CRM communication alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ADMIN_PHONE=

# Blog hero image generation (admin "Generieren")
# Provider: "gemini" (default) or "openai"
BLOG_IMAGE_PROVIDER=gemini
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
OPENAI_IMAGE_MODEL=gpt-image-1
