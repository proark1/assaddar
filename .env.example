# Public site/contact
RESEND_API_KEY=
CONTACT_FROM_EMAIL="ASSADDAR Website <hello@assad-dar.de>"
NEXT_PUBLIC_CAL_LINK=

# Assaddar AI communication widget. Empty = production only; true = force on; false = force off.
NEXT_PUBLIC_ASSADDAR_WIDGET_ENABLED=
NEXT_PUBLIC_ASSADDAR_WIDGET_URL=https://assaddar-widget-production.up.railway.app/widget.js
NEXT_PUBLIC_ASSADDAR_API_URL=https://assaddar-api-production.up.railway.app
NEXT_PUBLIC_ASSADDAR_ASSISTANT_ID=asst_5965790b88cc480b836f5eca

# Required before using the portal with real customers.
# Generate a long random value, for example:
# openssl rand -base64 48
AUTH_SECRET=
APP_URL=http://localhost:3000
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_COOKIE_DOMAIN=
PORTAL_ADMIN_BOOTSTRAP_PASSWORD=
CRON_SECRET=

# Portal data backend.
# local = development/demo JSON store in .portal-data
# postgres = Supabase/Postgres using DATABASE_URL
PORTAL_DATA_BACKEND=local
DATABASE_URL=

# Later production integrations
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PORTAL_FILE_STORAGE=local
SUPABASE_STORAGE_BUCKET=portal-files

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
GROK_API_KEY=
GROK_MODEL=
GROK_API_BASE=https://api.x.ai/v1

# Blog hero image generation (admin "Generieren")
# Provider: "gemini" (default) or "openai"
BLOG_IMAGE_PROVIDER=gemini
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
OPENAI_IMAGE_MODEL=gpt-image-1
