{
  "name": "assaddar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev",
    "dev:portal": "AUTH_SECRET=local-development-auth-secret-32chars PORTAL_DATA_BACKEND=local PORTAL_FILE_STORAGE=local next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "check:assets": "node scripts/check-assets.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:production": "node scripts/portal-production-check.mjs",
    "check:migrations": "node scripts/check-portal-migrations.mjs",
    "check": "pnpm typecheck && pnpm check:assets && pnpm check:links && pnpm check:migrations && pnpm test:security && pnpm build && pnpm test:portal",
    "deploy:railway": "pnpm check:production && pnpm check:migrations && railway up",
    "start": "next start",
    "start:portal-local": "AUTH_SECRET=local-development-auth-secret-32chars PORTAL_DATA_BACKEND=local PORTAL_FILE_STORAGE=local next start",
    "test:security": "tsx --test tests/portal-security.test.ts",
    "test:portal": "node scripts/portal-smoke.mjs"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "geist": "^1.3.1",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.5",
    "next": "^16.2.9",
    "playwright-core": "^1.61.1",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.16.0",
    "sanitize-html": "^2.17.0",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
